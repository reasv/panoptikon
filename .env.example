# Example .env file for Panoptikon.
# Copy this file to ".env" (in the repository root) and uncomment/set the
# values you want. Lines starting with "#" are comments and are ignored.
#
# The server auto-loads .env at startup. Environment variables are NOT a
# parallel configuration mechanism anymore: global configuration lives in
# TOML (config/gateway/*.toml), and string values there can reference
# environment variables via templating, e.g. level = "${LOGLEVEL:-INFO}".
# Variables set here feed those templates, plus the small bootstrap /
# diagnostic set documented below. Child processes (inference workers, the
# UI server) inherit the full environment, .env included.
#
# Full configuration reference: panoptikon/README.md

# ---- Template sources (referenced by the shipped TOMLs) ----

# Log level; feeds `level = "${LOGLEVEL:-INFO}"` in config/gateway/*.toml.
#LOGLEVEL=DEBUG

# API keys for models in the built-in inference registry
# (python/inferio/config/inference.toml).
#SAUCENAO_API_KEY=
#JINA_API_KEY=

# ---- Bootstrap / diagnostic variables (deliberately not TOML keys) ----

# Path to the server config file (--config on the command line wins).
# Default: config/gateway/default.toml relative to the working directory.
#GATEWAY_CONFIG_PATH=config/gateway/local.toml

# Standard tracing filter; overrides [logging].level when set and supports
# per-module directives.
#RUST_LOG=info

# Generic config override layer: GATEWAY__<KEY> (nested keys with __), e.g.:
#GATEWAY__SERVER__PORT=6342
#GATEWAY__DATA_FOLDER=data
#GATEWAY__LOGGING__LEVEL=debug

# Skip CUDA/cuDNN loader-path setup in inference workers.
#NO_CUDNN=true

# Dev/diagnostic overrides for bundled native dependencies.
#PDFIUM_PATH=
#HTML_RENDERER_PATH=
#PANOPTIKON_FONT=
